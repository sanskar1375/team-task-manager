# Root env. Server reads its own .env in server/. This file documents what
# Railway needs in production for the single-service deploy.

# Postgres (Railway provides automatically when you add the Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — generate a long random string for production
JWT_SECRET=replace_with_64_byte_random_hex

# Node environment
NODE_ENV=production

# Port (Railway sets PORT automatically; leave unset there)
PORT=4000

# Allowed origin for CORS. In the single-service Railway deploy, the client is
# served from the same origin as the API so this can be the deploy URL itself.
CORS_ORIGIN=https://your-app.up.railway.app
