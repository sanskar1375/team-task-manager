{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./node_modules/.tmp/tsconfig-node-out",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig-node.tsbuildinfo"
  },
  "include": ["vite.config.ts", "tailwind.config.ts"]
}
