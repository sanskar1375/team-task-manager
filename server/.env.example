# Local Postgres connection. Either install Postgres or run via Docker:
#   docker run --name ttm-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/team_task_manager?schema=public

# JWT signing secret. Use a long random string (32+ chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev_secret_change_me_to_a_long_random_string_at_least_32_chars_long

# Node environment
NODE_ENV=development

# API port (Railway sets PORT automatically in production)
PORT=4000

# Allowed CORS origin for the Vite dev server
CORS_ORIGIN=http://localhost:5173
